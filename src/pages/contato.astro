---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contato — Studio Crystal Lashes · Santo André, SP"
  description="Entre em contato com o Studio Crystal Lashes. WhatsApp, endereço, horários e localização em Santo André, SP."
>

  <section class="page-hero section--dark">
    <div class="container page-hero__inner">
      <div class="reveal">
        <p class="eyebrow">Fale conosco</p>
        <h1 style="margin: 12px 0 16px;">Agende seu<br /><em>horário</em></h1>
        <p style="color: rgba(255,255,255,0.6); max-width: 440px; line-height: 1.75;">
          A forma mais rápida de agendar é pelo WhatsApp. Respondemos em minutos.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contato-grid">

        <div class="contato-info">
          <div class="info-block reveal">
            <h2>WhatsApp</h2>
            <p class="text-muted">Atendimento rápido, dúvidas e agendamentos.</p>
            <a
              href="https://wa.me/5511916637446?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20um%20hor%C3%A1rio!"
              class="btn btn--primary wa-btn"
              target="_blank"
              rel="noopener"
            >
              Abrir WhatsApp
            </a>
            <p class="phone-display">(11) 91663-7446</p>
          </div>

          <div class="info-block reveal reveal-delay-1">
            <h3>Endereço</h3>
            <address>
              <p>Av. João Ramalho, 170, Sala 702</p>
              <p>Vila Assunção, Santo André, SP</p>
              <p>CEP 09030-320</p>
            </address>
          </div>

          <div class="info-block reveal reveal-delay-2">
            <h3>Horários de atendimento</h3>
            <table class="hours-table">
              <tbody>
                <tr>
                  <td>Terça a Sexta</td>
                  <td><strong>9h – 19h</strong></td>
                </tr>
                <tr>
                  <td>Sábado</td>
                  <td class="text-muted">Fechado</td>
                </tr>
                <tr>
                  <td>Domingo e Segunda</td>
                  <td class="text-muted">Fechado</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="info-block reveal reveal-delay-3">
            <h3>Redes sociais</h3>
            <div class="social-links">
              <a href="https://www.instagram.com/studiocrystallashes/" target="_blank" rel="noopener" class="social-link social-link--instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
                @studiocrystallashes
              </a>
              <a href="https://www.tiktok.com/@crystallashesstudio" target="_blank" rel="noopener" class="social-link social-link--tiktok">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34v-7a8.16 8.16 0 0 0 4.77 1.52V6.4a4.85 4.85 0 0 1-1-.29z"/>
                </svg>
                @crystallashesstudio
              </a>
            </div>
          </div>
        </div>

        <div class="contato-map reveal">
          <iframe
            src="https://maps.google.com/maps?q=Av+Jo%C3%A3o+Ramalho+170+Vila+Assun%C3%A7%C3%A3o+Santo+Andr%C3%A9+SP&output=embed"
            width="100%"
            height="420"
            style="border:0; border-radius: var(--radius-lg);"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localização Studio Crystal Lashes — Av. João Ramalho 170, Sala 702, Vila Assunção, Santo André"
          ></iframe>
          <a
            href="https://maps.google.com/maps?q=Av+Jo%C3%A3o+Ramalho+170+Vila+Assun%C3%A7%C3%A3o+Santo+Andr%C3%A9+SP"
            class="btn btn--outline maps-btn"
            target="_blank"
            rel="noopener"
          >
            Abrir no Google Maps
          </a>
          <p class="map-note text-muted">
            Acesso pela Av. João Ramalho. Estacionamento disponível nas proximidades.
          </p>
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding: 100px 0 60px;
  }

  .page-hero__inner { padding-top: 0; padding-bottom: 0; }

  /* Grid principal */
  .contato-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: start;
  }

  @media (min-width: 768px) {
    .contato-grid {
      grid-template-columns: 1fr 1.4fr;
      gap: 64px;
    }

    .contato-map {
      position: sticky;
      top: 88px;
    }
  }

  .contato-info {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Blocos de info */
  .info-block h2 {
    font-size: 1.8rem;
    color: var(--teal-deep);
    margin-bottom: 8px;
  }

  .info-block h3 {
    color: var(--teal-deep);
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.72rem;
    margin-bottom: 14px;
  }

  .info-block h3::before {
    content: '✦ ';
    color: var(--calcita);
    font-size: 0.6rem;
  }

  .info-block p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .wa-btn {
    margin-top: 16px;
    margin-bottom: 12px;
  }

  .phone-display {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 4px;
  }

  address {
    font-style: normal;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.85;
  }

  /* Tabela de horários */
  .hours-table {
    width: 100%;
    border-collapse: collapse;
  }

  .hours-table td {
    padding: 10px 0;
    font-size: 0.88rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--line);
  }

  .hours-table tr:last-child td { border-bottom: none; }

  .hours-table td:last-child { text-align: right; }

  .hours-table strong { color: var(--teal-deep); }

  /* Redes sociais */
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    color: var(--calcita);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .social-link--instagram:hover { color: #E4405F; }
  .social-link--tiktok:hover { color: #111; }

  /* Mapa */
  .maps-btn {
    display: block;
    width: 100%;
    text-align: center;
    margin-top: 12px;
  }

  .map-note {
    margin-top: 12px;
    font-size: 0.8rem;
    text-align: center;
  }
</style>

