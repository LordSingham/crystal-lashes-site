---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Base
  title="Blog — Extensão de Cílios e Cuidados · Studio Crystal Lashes"
  description="Dicas, guias e tudo sobre extensão de cílios, harmonização do olhar e cuidados com lash em Santo André, SP."
>

  <section class="page-hero section--dark">
    <div class="container">
      <div class="reveal">
        <p class="eyebrow">Conhecimento Crystal</p>
        <h1>Blog</h1>
        <p style="color: rgba(255,255,255,0.6); margin-top: 16px; max-width: 480px; line-height: 1.7;">
          Tudo o que você precisa saber sobre extensão de cílios, harmonização do olhar e cuidados com extensão e cílios.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="blog-section-head reveal">
        <p class="eyebrow">Guias Crystal</p>
        <h2>Conteúdo para cuidar melhor do seu olhar</h2>
      </div>
      {posts.length === 0 ? (
        <div class="empty-blog text-center reveal">
          <p class="text-muted">Artigos em breve. Fique de olho!</p>
          <a href="https://www.instagram.com/studiocrystallashes/" class="btn btn--primary" style="margin-top: 20px;" target="_blank" rel="noopener">
            Enquanto isso, siga no Instagram
          </a>
        </div>
      ) : (
        <div class="blog-grid">
          {posts.map((post, i) => (
            <article class={`blog-card reveal reveal-delay-${(i % 4) + 1}`}>
              {post.data.image && (
                <a href={`/blog/${post.id}`} class="blog-card__img-link">
                  <img src={post.data.image} alt={post.data.title} loading={i === 0 ? 'eager' : 'lazy'} width="640" height="360" />
                </a>
              )}
              <div class="blog-card__body">
                <div class="blog-card__meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric', timeZone: 'UTC' })}
                  </time>
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="blog-tag">{tag}</span>
                  ))}
                </div>
                <h2 class="blog-card__title">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="blog-card__desc">{post.data.description}</p>
                <a href={`/blog/${post.id}`} class="blog-card__link">Ler artigo ✦</a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding: 100px 0 60px;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
    gap: 32px;
    align-items: stretch;
  }

  .blog-section-head {
    max-width: 680px;
    margin-bottom: 40px;
  }

  .blog-section-head h2 { margin-top: 10px; }

  .blog-card {
    border: var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--white);
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-soft);
    border-color: var(--calcita);
  }

  .blog-card__img-link {
    display: block;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--calcita-soft);
  }

  .blog-card__img-link img {
    width: 100%;
    height: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .blog-card__body {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .blog-card__meta time {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .blog-tag {
    font-size: 0.7rem;
    background: var(--calcita-light);
    color: var(--teal-deep);
    padding: 2px 8px;
    border-radius: var(--radius-pill);
  }

  .blog-card__title {
    font-size: 1.2rem;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .blog-card__title a {
    color: var(--teal-deep);
    transition: color var(--transition-fast);
  }

  .blog-card__title a:hover {
    color: var(--calcita);
  }

  .blog-card__desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .blog-card__link {
    margin-top: auto;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--calcita);
    transition: color var(--transition-fast);
  }

  .blog-card__link:hover {
    color: var(--teal-dark);
  }

  .empty-blog {
    padding: 80px 0;
  }
</style>

