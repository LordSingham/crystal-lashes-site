---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Testimonial from '../components/Testimonial.astro';

const services = [
  {
    name: 'Volume Crystal',
    description: 'Nossa técnica exclusiva. Mapeamento personalizado que harmoniza extensão, curvatura e espessura ao formato natural dos seus olhos.',
    price: 'R$210',
    duration: '2h30 – 3h',
    highlight: true,
  },
  {
    name: 'Volume Egípcio / Fox Eyes',
    description: 'Efeito alongado e dramático que eleva o olhar. Mapeamento com fio mais longo nas extremidades para um resultado marcante.',
    price: 'R$220',
    duration: '2h30 – 3h',
  },
  {
    name: 'Extensão Elegance',
    description: 'Clássica e sofisticada. Define o olhar de forma natural e delicada, sem exageros — ideal para o dia a dia.',
    price: 'R$200',
    duration: '2h – 2h30',
  },
  {
    name: 'Manutenção',
    description: 'Reposição dos fios para manter o visual impecável. Recomendada a cada 21–28 dias.',
    price: 'R$120–150',
    duration: '1h – 1h30',
  },
];

const testimonials = [
  {
    name: 'Amanda Brinholi',
    text: 'Atendimento único, ela sempre respeita o gosto do cliente e sempre me surpreende no resultado impecável. É muito difícil achar uma profissional de cílios que também preze pela saúde das clientes — a Ste é extremamente cuidadosa com a limpeza do studio e dos materiais.',
  },
  {
    name: 'Victoria Psd',
    text: 'Sempre faço os cílios com essa profissional excelente! A melhor do ABC, e indico para todo mundo. Super cuidadosa, atenciosa! Nota MIL. Não troco por nada!',
  },
  {
    name: 'Natalia Santos',
    text: 'Materiais de ótima qualidade e honestidade no resultado. Fica um trabalho muito natural mesmo sendo com um volume maior de cílios — ela leva em consideração os fios do cliente, sendo realista e não apenas fazendo para ganhar o dinheiro.',
  },
];

const reviewImages = [
  { src: '/reviews/review-01.jpg', alt: 'Avaliação Google — Studio Crystal Lashes' },
  { src: '/reviews/review-02.jpg', alt: 'Avaliação Google — Studio Crystal Lashes' },
  { src: '/reviews/review-03.jpg', alt: 'Avaliação Google — Studio Crystal Lashes' },
  { src: '/reviews/review-04.jpg', alt: 'Avaliação Google — Studio Crystal Lashes' },
  { src: '/reviews/review-05.jpg', alt: 'Avaliação Google — Studio Crystal Lashes' },
  { src: '/reviews/review-06.jpg', alt: 'Avaliação Google — Studio Crystal Lashes' },
];
---

<Base
  title="Studio Crystal Lashes — Extensão de Cílios em Santo André, SP"
  description="Especialistas em Harmonização do Olhar e Extensão de Cílios em Santo André, SP. Técnica Crystal exclusiva. Agende pelo WhatsApp."
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__content">
        <p class="eyebrow">Studio Crystal Lashes · Santo André, SP</p>
        <h1>O olhar que você merece,<br /><em>no formato que te harmoniza.</em></h1>
        <p class="hero__sub">
          Extensão de cílios com mapeamento exclusivo para harmonizar cada formato de olho.
          Mais de 7 anos transformando olhares em Vila Assunção.
        </p>
        <div class="hero__actions">
          <a href="https://wa.me/5511916637446?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20um%20hor%C3%A1rio!" class="btn btn--primary" target="_blank" rel="noopener">
            Agendar pelo WhatsApp
          </a>
          <a href="/servicos" class="btn btn--outline">Ver serviços</a>
        </div>
        <div class="hero__trust">
          <div class="trust-item">
            <strong>7+</strong><span>anos de experiência</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <strong>4.8★</strong><span>no Google (46 avaliações)</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <strong>Meta Verified</strong><span>@studiocrystallashes</span>
          </div>
        </div>
      </div>
      <div class="hero__photo">
        <img
          src="/portfolio/antes-depois-01.jpg"
          alt="Resultado antes e depois — Extensão de Cílios Volume Crystal, Studio Crystal Lashes Santo André"
          loading="eager"
        />
        <span class="hero__sparkle" aria-hidden="true">✦</span>
      </div>
    </div>
  </section>

  <!-- Diferencial -->
  <section class="section">
    <div class="container">
      <div class="diff-intro text-center">
        <p class="eyebrow">Por que Crystal Lashes</p>
        <h2>Cada olho tem uma história.<br />Sabemos contar a sua.</h2>
        <p class="text-muted diff-sub">Não aplicamos cílios. Projetamos harmonias. O Mapeamento Crystal analisa o formato do olho, a curvatura natural e o estilo de vida para criar um resultado personalizado — que parece natural porque foi feito para você.</p>
      </div>
      <div class="diff-grid">
        <div class="diff-item">
          <div class="diff-icon">✦</div>
          <h3>Mapeamento Crystal</h3>
          <p>Técnica exclusiva que analisa o formato do seu olho para definir a curvatura, espessura e comprimento ideais. Resultado: harmonia, não exagero.</p>
        </div>
        <div class="diff-item">
          <div class="diff-icon">✦</div>
          <h3>Lash Nap</h3>
          <p>Ambiente pensado para seu conforto. Música suave, temperatura agradável e luz calibrada. Muitas clientes dormem durante o procedimento.</p>
        </div>
        <div class="diff-item">
          <div class="diff-icon">✦</div>
          <h3>7 anos de precisão</h3>
          <p>Stefanie Moura acumulou 7 anos especializando o olhar clínico para lash e 3 anos na Harmonização do Olhar — a combinação que entrega exatamente o resultado certo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Serviços Preview -->
  <section class="section section--muted">
    <div class="container">
      <div class="text-center" style="margin-bottom: 48px;">
        <p class="eyebrow">Serviços</p>
        <h2>Do clássico ao exclusivo</h2>
      </div>
      <div class="grid-2">
        {services.map((s) => <ServiceCard {...s} />)}
      </div>
      <div class="text-center" style="margin-top: 40px;">
        <a href="/servicos" class="btn btn--primary">Ver todos os serviços</a>
      </div>
    </div>
  </section>

  <!-- Depoimentos -->
  <section class="section section--dark">
    <div class="container">
      <div class="text-center" style="margin-bottom: 48px;">
        <p class="eyebrow">O que as clientes dizem</p>
        <h2 style="color: #fff;">Resultados que falam<br /><em>por si mesmos</em></h2>
      </div>
      <div class="grid-3">
        {testimonials.map((t) => <Testimonial {...t} />)}
      </div>
    </div>
  </section>

  <!-- Avaliações Google -->
  <section class="section reviews-section">
    <div class="container">
      <div class="text-center" style="margin-bottom: 40px;">
        <p class="eyebrow">Avaliações no Google</p>
        <h2>4.8★ · 46 avaliações verificadas</h2>
        <p class="text-muted" style="margin-top: 12px; font-size: 0.9rem;">Clientes reais, resultados reais.</p>
      </div>
      <div class="reviews-grid">
        {reviewImages.map((r) => (
          <div class="review-img-wrap">
            <img src={r.src} alt={r.alt} loading="lazy" />
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: 40px;">
        <a href="https://g.page/r/StudioCrystalLashes/review" class="btn btn--primary" target="_blank" rel="noopener">
          Ver todas no Google
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="section cta-final section--dark">
    <div class="container text-center">
      <p class="eyebrow">Pronta para transformar seu olhar?</p>
      <h2 style="color: #fff;">Agende seu horário<br /><em>ainda hoje</em></h2>
      <p style="color: rgba(255,255,255,0.6); margin-top: 12px; font-size: 0.9rem;">Terça a sexta · Vila Assunção, Santo André – SP</p>
      <a href="https://wa.me/5511916637446?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20um%20hor%C3%A1rio!" class="btn btn--primary cta-btn" target="_blank" rel="noopener">
        Falar no WhatsApp
      </a>
    </div>
  </section>

</Base>

<style>
  /* ── Hero ── */
  .hero {
    background: var(--teal-deep);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
    padding-top: 100px;
    padding-bottom: 80px;
  }

  .hero__content .eyebrow {
    margin-bottom: 20px;
  }

  .hero__content h1 {
    color: #fff;
    max-width: 600px;
    margin-bottom: 24px;
  }

  .hero__content h1 em {
    color: var(--teal);
    font-style: italic;
  }

  .hero__sub {
    color: rgba(255,255,255,0.65);
    font-size: 1.05rem;
    max-width: 480px;
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .hero__actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .hero__trust {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-item strong {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: #fff;
    line-height: 1;
  }

  .trust-item span {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.04em;
  }

  .trust-divider {
    width: 1px;
    height: 32px;
    background: rgba(255,255,255,0.12);
  }

  .hero__photo {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.4);
  }

  .hero__sparkle {
    position: absolute;
    top: -14px;
    right: -14px;
    font-size: 2rem;
    color: var(--teal);
    animation: sparkle-pulse 2.5s ease-in-out infinite;
  }

  @keyframes sparkle-pulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.12); }
  }

  .hero__photo img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    object-position: center top;
  }

  @media (max-width: 860px) {
    .hero__inner {
      grid-template-columns: 1fr;
      padding-top: 80px;
      padding-bottom: 60px;
      gap: 40px;
    }
    .hero__photo img {
      height: 340px;
    }
  }

  /* ── Diferencial ── */
  .diff-intro {
    max-width: 640px;
    margin: 0 auto 56px;
  }

  .diff-sub {
    margin-top: 16px;
    font-size: 1rem;
    line-height: 1.7;
  }

  .diff-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 32px;
  }

  .diff-item {
    padding: 32px;
    border: 1px solid #E2E8F0;
    border-radius: 8px;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .diff-item:hover {
    border-color: var(--teal);
    box-shadow: 0 4px 24px rgba(94, 207, 191, 0.12);
  }

  .diff-icon {
    font-size: 1.6rem;
    color: var(--teal);
    margin-bottom: 16px;
    transition: transform 0.25s;
  }

  .diff-item:hover .diff-icon {
    transform: scale(1.15);
  }

  .diff-item h3 {
    font-size: 1.2rem;
    margin-bottom: 12px;
    color: var(--teal-deep);
  }

  .diff-item p {
    font-size: 0.9rem;
    color: var(--gray-600);
    line-height: 1.7;
  }

  /* ── Avaliações Google ── */
  .reviews-section {
    background: var(--gray-50);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .review-img-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    background: #fff;
    border: 1px solid #E2E8F0;
  }

  .review-img-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── CTA Final ── */
  .cta-btn {
    margin-top: 32px;
    padding: 16px 40px;
    font-size: 0.95rem;
  }
</style>
