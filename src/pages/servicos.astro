---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';

const lashServices = [
  {
    name: 'Volume Crystal',
    description: 'A técnica exclusiva do Studio Crystal Lashes. O Mapeamento Crystal analisa o formato individual do olho para definir a curvatura, comprimento e espessura ideais. Resultado: um olhar harmonizado que parece natural — porque foi feito para você.',
    price: 'R$210',
    duration: '2h30 – 3h',
    highlight: true,
  },
  {
    name: 'Volume Egípcio / Fox Eyes',
    description: 'Efeito alongado e dramático. Mapeamento com fios mais longos nas extremidades para elevar e alongar o olhar. Ideal para quem quer presença e impacto.',
    price: 'R$220',
    duration: '2h30 – 3h',
  },
  {
    name: 'Extensão Elegance / Brasileiro',
    description: 'Clássica e sofisticada. Define o olhar de forma delicada e natural, sem exageros. A escolha perfeita para o dia a dia profissional.',
    price: 'R$200',
    duration: '2h – 2h30',
  },
  {
    name: 'Manutenção',
    description: 'Reposição dos fios caídos para manter o visual impecável entre sessões completas. Recomendada a cada 21–28 dias para resultado duradouro.',
    price: 'R$120–150',
    duration: '1h – 1h30',
  },
  {
    name: 'Lash Lifting',
    description: 'Curvatura e definição nos seus cílios naturais. Sem extensão, sem fios — apenas o potencial do seu próprio cílio revelado. Dura até 8 semanas.',
    price: 'R$200',
    duration: '1h',
  },
];

const browServices = [
  {
    name: 'Design de Sobrancelha',
    description: 'Modelagem precisa que enquadra e harmoniza o rosto. Técnica manual ou com linha, definindo o arco ideal para o formato do seu rosto.',
    price: 'R$75',
    duration: '30–40 min',
  },
  {
    name: 'Brow Lamination',
    description: 'Sobrancelhas fixadas na direção certa, com aspecto natural e volumoso. Efeito dura até 6–8 semanas. Inclui design.',
    price: 'R$190',
    duration: '1h',
  },
];
---

<Base
  title="Serviços e Preços — Studio Crystal Lashes, Santo André"
  description="Extensão de cílios, Lash Lifting, Design de Sobrancelha e Brow Lamination em Santo André, SP. Preços e informações completas."
>

  <section class="page-hero section section--dark">
    <div class="container">
      <p class="eyebrow">O que oferecemos</p>
      <h1 style="color: #fff;">Serviços<br /><em>& Preços</em></h1>
      <p style="color: rgba(255,255,255,0.6); margin-top: 16px; max-width: 480px; line-height: 1.7;">
        Todos os procedimentos realizados com avaliação individual do olhar. Nada genérico.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Extensão de Cílios</p>
      <h2 style="margin-bottom: 40px;">Cílios</h2>
      <div class="grid-2">
        {lashServices.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <section class="section section--muted">
    <div class="container">
      <p class="eyebrow">Sobrancelhas</p>
      <h2 style="margin-bottom: 40px;">Brows</h2>
      <div class="grid-2">
        {browServices.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container">
      <div class="text-center" style="margin-bottom: 48px;">
        <p class="eyebrow">Antes de agendar</p>
        <h2>Perguntas frequentes</h2>
      </div>
      <div class="faq-grid">
        <details class="faq-item">
          <summary>Quanto tempo dura a extensão?</summary>
          <p>Em média 3–4 semanas com cuidados adequados. A manutenção a cada 21–28 dias mantém o visual impecável de forma contínua.</p>
        </details>
        <details class="faq-item">
          <summary>A extensão danifica o cílio natural?</summary>
          <p>Não, quando aplicada corretamente. O Mapeamento Crystal respeita o peso e a capacidade de cada cílio natural. Nunca aplicamos fios mais pesados do que o cílio suporta.</p>
        </details>
        <details class="faq-item">
          <summary>Posso usar máscara de cílios?</summary>
          <p>Não é necessário e não é recomendado. A extensão já oferece o volume e o comprimento desejados. Mascar à base de óleo compromete a durabilidade da cola.</p>
        </details>
        <details class="faq-item">
          <summary>O que é o Lash Nap?</summary>
          <p>A maioria das clientes dorme durante o procedimento. O studio tem temperatura controlada, música ambiente e luz calibrada para criar um ambiente relaxante. É uma das marcas do Crystal Lashes.</p>
        </details>
        <details class="faq-item">
          <summary>Como fazer para agendar?</summary>
          <p>Pelo WhatsApp — clique em qualquer botão "Agendar" neste site. O atendimento é de terça a sexta-feira na Av. João Ramalho, 170, Sala 702, Vila Assunção, Santo André.</p>
        </details>
        <details class="faq-item">
          <summary>Tenho alergia a cola. Posso fazer?</summary>
          <p>Depende do tipo de sensibilidade. Entre em contato antes de agendar para conversarmos sobre o histórico e eventualmente realizarmos um teste de contato.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="section section--dark cta-serv">
    <div class="container text-center">
      <h2 style="color: #fff;">Pronta para agendar?</h2>
      <p style="color: rgba(255,255,255,0.6); margin: 16px 0 32px;">
        Terça a sexta · Vila Assunção, Santo André · (11) 91663-7446
      </p>
      <a href="https://wa.me/5511916637446?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20um%20hor%C3%A1rio!" class="btn btn--primary" target="_blank" rel="noopener">
        Falar no WhatsApp
      </a>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding: 100px 24px 60px;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 16px;
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-item {
    border: 1px solid #E2E8F0;
    border-radius: 8px;
    overflow: hidden;
  }

  .faq-item summary {
    padding: 20px 24px;
    font-weight: 500;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    color: #0F2820;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: '+';
    font-size: 1.2rem;
    color: #5ECFBF;
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    padding: 0 24px 20px;
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.7;
  }
</style>

