---
import Base from '../layouts/Base.astro';

const galeria = [
  { src: '/fotos/resultados/resultado-volume-crystal-01.jpg', thumb: '/fotos/resultados/resultado-volume-crystal-01.jpg', alt: 'Resultado Volume Crystal 01', tecnica: 'Volume Crystal', width: 2048, height: 2048 },
  { src: '/fotos/resultados/resultado-fox-eyes-01.jpg', thumb: '/fotos/resultados/resultado-fox-eyes-01.jpg', alt: 'Resultado Fox Eyes 01', tecnica: 'Fox Eyes', width: 2268, height: 2835 },
  { src: '/fotos/resultados/resultado-elegance-01.jpeg', thumb: '/fotos/resultados/resultado-elegance-01.jpeg', alt: 'Resultado Elegance 01', tecnica: 'Elegance', width: 2048, height: 2048 },
  { src: '/fotos/resultados/resultado-volume-brasileiro-01.jpg', thumb: '/fotos/resultados/resultado-volume-brasileiro-01.jpg', alt: 'Resultado Volume Brasileiro 01', tecnica: 'Volume Brasileiro', width: 2048, height: 2048 },
  { src: '/fotos/resultados/resultado-volume-crystal-02.jpg', thumb: '/fotos/resultados/resultado-volume-crystal-02.jpg', alt: 'Resultado Volume Crystal 02', tecnica: 'Volume Crystal', width: 1642, height: 2053 },
  { src: '/fotos/resultados/resultado-fox-eyes-02.jpg', thumb: '/fotos/resultados/resultado-fox-eyes-02.jpg', alt: 'Resultado Fox Eyes 02', tecnica: 'Fox Eyes', width: 2048, height: 2048 },
  { src: '/fotos/resultados/resultado-volume-brasileiro-02.jpg', thumb: '/fotos/resultados/resultado-volume-brasileiro-02.jpg', alt: 'Resultado Volume Brasileiro 02', tecnica: 'Volume Brasileiro', width: 2048, height: 2048 },
  { src: '/fotos/resultados/resultado-volume-crystal-03.jpg', thumb: '/fotos/resultados/resultado-volume-crystal-03.jpg', alt: 'Resultado Volume Crystal 03', tecnica: 'Volume Crystal', width: 2048, height: 2048 },
  { src: '/fotos/resultados/resultado-editorial.png', thumb: '/fotos/resultados/resultado-editorial.png', alt: 'Aplicação Volume Crystal', tecnica: 'Aplicação Crystal', width: 2520, height: 1890 },
];

const espacoFotos = [
  { src: '/fotos/espaco/espaco-01.png', alt: 'Ambiente do Studio Crystal Lashes' },
  { src: '/fotos/espaco/espaco-02.png', alt: 'Bancada de aplicação do studio' },
  { src: '/fotos/espaco/espaco-03.png', alt: 'Detalhe do estúdio Crystal Lashes' },
  { src: '/fotos/espaco/espaco-04.png', alt: 'Recepção do studio Crystal Lashes' },
];

const depoimentos = [
  {
    name: 'Amanda Brinholi',
    text: 'Atendimento único, ela sempre respeita o gosto do cliente e sempre me surpreende no resultado impecável. É muito difícil achar uma profissional de cílios que também preze pela saúde das clientes, a Ste é extremamente cuidadosa com a limpeza do studio e dos materiais.',
    stars: 5,
  },
  {
    name: 'Victoria Psd',
    text: 'Sempre faço os cílios com essa profissional excelente! A melhor do ABC, e indico para todo mundo. Super cuidadosa, atenciosa! Nota MIL. Não troco por nada!',
    stars: 5,
  },
  {
    name: 'Natalia Santos',
    text: 'Materiais de ótima qualidade e honestidade no resultado. Fica um trabalho muito natural mesmo sendo com um volume maior de cílios, ela leva em consideração os fios do cliente, sendo realista e não apenas fazendo para ganhar o dinheiro.',
    stars: 5,
  },
  {
    name: 'Patricia Oliveira',
    text: 'Stefanie é incrível! Fiz o Volume Crystal e fiquei apaixonada. O studio é impecável, ela é super atenciosa e o resultado ficou perfeito. Já indiquei para várias amigas.',
    stars: 5,
  },
];
---

<Base
  title="Resultados — Studio Crystal Lashes, Santo André"
  description="Veja transformações reais do Studio Crystal Lashes. Volume Crystal, Fox Eyes, Elegance e Egípcio. Galeria de resultados em Santo André, SP."
>

  <!-- Hero -->
  <section class="res-hero section--dark">
    <div class="container res-hero__inner">
      <div class="reveal">
        <p class="eyebrow">Galeria</p>
        <h1 style="margin: 12px 0 16px;">Transformações<br /><em>que falam por si</em></h1>
        <p style="color: rgba(255,255,255,0.6); max-width: 480px; line-height: 1.75;">
          Cada resultado é único porque cada olho é único. Veja o que o Mapeamento Crystal entrega na prática.
        </p>
      </div>
    </div>
  </section>

  <!-- Galeria editorial com PhotoSwipe -->
  <section class="section">
    <div class="container">
      <div class="text-center reveal" style="margin-bottom: 48px;">
        <p class="eyebrow">Resultados</p>
        <h2>Galeria de trabalhos</h2>
      </div>
      <div class="pswp-gallery galeria-grid" id="galeria">
        {galeria.map((foto, i) => (
          <a
            href={foto.src}
            data-pswp-width={foto.width}
            data-pswp-height={foto.height}
            class={`galeria-item reveal ${i === 0 ? 'galeria-item--featured' : ''} reveal-delay-${(i % 4) + 1}`}
            aria-label={foto.alt}
          >
            <img src={foto.thumb} alt={foto.alt} loading={i < 3 ? 'eager' : 'lazy'} width="400" height="400" />
            <span class="galeria-label">{foto.tecnica}</span>
          </a>
        ))}
      </div>
      <div class="text-center reveal" style="margin-top: 40px;">
        <a href="https://www.instagram.com/studiocrystallashes" class="btn btn--outline" target="_blank" rel="noopener">
          Ver mais no Instagram
        </a>
      </div>
    </div>
  </section>

  <!-- Espaço do Studio -->
  <section class="section section--calcita espaco">
    <div class="container">
      <div class="text-center reveal" style="margin-bottom: 48px;">
        <p class="eyebrow">O ambiente</p>
        <h2>O studio por dentro</h2>
      </div>
      <div class="pswp-gallery espaco-grid" id="espaco">
        {espacoFotos.map((foto, i) => (
          <a
            href={foto.src}
            data-pswp-width="800"
            data-pswp-height="600"
            class={`espaco-item reveal reveal-delay-${i + 1}`}
            aria-label={foto.alt}
            title="Clique para ampliar"
          >
            <img src={foto.src} alt={foto.alt} loading={i < 2 ? 'eager' : 'lazy'} width="800" height="600" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Depoimentos Swiper -->
  <section class="section section--dark depoimentos">
    <div class="container">
      <div class="text-center reveal" style="margin-bottom: 48px;">
        <p class="eyebrow">Avaliações Google</p>
        <h2 style="color: #fff;">O que as clientes dizem</h2>
        <p style="color: rgba(255,255,255,0.4); margin-top: 10px; font-size: 0.82rem; letter-spacing: 0.06em;">4.8★ · 46 avaliações</p>
      </div>
      <div class="swiper dep-swiper">
        <div class="swiper-wrapper">
          {depoimentos.map((d) => (
            <div class="swiper-slide">
              <blockquote class="dep-card">
                <div class="dep-stars">{"★".repeat(d.stars)}</div>
                <p class="dep-text">"{d.text}"</p>
                <footer class="dep-author">{d.name}</footer>
              </blockquote>
            </div>
          ))}
        </div>
        <div class="swiper-pagination dep-pagination"></div>
      </div>
      <div class="text-center" style="margin-top: 40px;">
        <a href="https://goo.gl/maps/fU1T5ZW75svgxD9U7" class="btn btn--outline-white" target="_blank" rel="noopener">
          Ver todas no Google
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--calcita-brand">
    <div class="container text-center">
      <p class="eyebrow" style="color: var(--teal-deep);">Quer ser a próxima?</p>
      <h2 style="color: var(--teal-deep); margin-top: 12px;">Agende sua sessão<br /><em>com a Stefanie</em></h2>
      <a href="https://wa.me/5511916637446?text=Ol%C3%A1%2C%20vi%20os%20resultados%20e%20quero%20agendar!" class="btn btn--primary" style="margin-top: 32px;" target="_blank" rel="noopener">
        Agendar pelo WhatsApp
      </a>
    </div>
  </section>

</Base>

<style>
  /* ── Hero ── */
  .res-hero {
    padding: 100px 0 60px;
  }

  .res-hero__inner { padding-top: 0; padding-bottom: 0; }

  /* ── Galeria editorial ── */
  /* Mobile: 2 cols, todos iguais */
  .galeria-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  /* Desktop: 4 cols, primeiro item ocupa 2x2 */
  @media (min-width: 768px) {
    .galeria-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 200px;
      grid-auto-flow: dense;
    }

    .galeria-item--featured {
      grid-column: span 2;
      grid-row: span 2;
    }

    .galeria-item--featured img {
      aspect-ratio: unset;
      height: 100%;
    }
  }

  .galeria-item {
    position: relative;
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .galeria-item img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .galeria-item:hover img { transform: scale(1.06); }

  .galeria-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(15,40,32,0.8), transparent);
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 32px 14px 12px;
  }

  /* ── Espaço ── */
  .espaco-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media (min-width: 768px) {
    .espaco-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .espaco-item {
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: zoom-in;
  }

  .espaco-item img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .espaco-item:hover img { transform: scale(1.04); }

  :global(.pswp) {
    z-index: 10000 !important;
  }

  :global(.pswp__bg) {
    background: rgb(6, 24, 18) !important;
  }

  :global(.pswp__top-bar) {
    background: rgb(6, 24, 18) !important;
  }

  /* ── Depoimentos Swiper ── */
  .dep-swiper {
    padding-bottom: 48px !important;
  }

  .dep-swiper .swiper-wrapper {
    align-items: stretch;
  }

  .dep-swiper .swiper-slide {
    height: auto;
    display: flex;
  }

  .dep-card {
    width: 100%;
    min-height: 300px;
    background: rgba(255,255,255,0.075);
    border: 1px solid rgba(255,255,255,0.13);
    border-left: 3px solid var(--calcita);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: 28px 32px;
    height: 100%;
    box-shadow: 0 18px 38px rgba(0,0,0,0.13);
    display: flex;
    flex-direction: column;
  }

  .dep-stars {
    color: var(--calcita);
    font-size: 0.9rem;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .dep-text {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.85);
    font-style: italic;
  }

  .dep-author {
    margin-top: auto;
    padding-top: 16px;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.05em;
  }

  .dep-pagination {
    bottom: 0 !important;
  }

  :global(.dep-pagination .swiper-pagination-bullet) {
    background: rgba(255,255,255,0.3);
  }

  :global(.dep-pagination .swiper-pagination-bullet-active) {
    background: var(--calcita);
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  // Inicia lightbox para galeria de resultados e fotos do espaço
  ['#galeria', '#espaco'].forEach((selector) => {
    const lightbox = new PhotoSwipeLightbox({
      gallery: selector,
      children: 'a',
      pswpModule: () => import('photoswipe'),
    });
    lightbox.init();
  });

  // Swiper para depoimentos
  import Swiper from 'swiper';
  import { Autoplay, Pagination } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/pagination';

  new Swiper('.dep-swiper', {
    modules: [Autoplay, Pagination],
    slidesPerView: 1,
    spaceBetween: 24,
    loop: true,
    speed: 600,
    pagination: {
      el: '.dep-pagination',
      clickable: true,
    },
    autoplay: {
      delay: 2000,
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    },
    breakpoints: {
      640: { slidesPerView: 1 },
      768: { slidesPerView: 2 },
      1024: { slidesPerView: 3 },
    },
  });
</script>
