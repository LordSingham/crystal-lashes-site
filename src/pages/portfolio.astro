---
import Base from '../layouts/Base.astro';

const photos = [
  {
    src: '/portfolio/antes-depois-01.jpg',
    alt: 'Antes e depois Volume Crystal — Studio Crystal Lashes Santo André',
    label: 'Volume Crystal',
    sub: 'Mapeamento personalizado',
  },
  {
    src: '/portfolio/antes-depois-02.jpg',
    alt: 'Antes e depois extensão de cílios — Studio Crystal Lashes',
    label: 'Volume Crystal',
    sub: 'Harmonia com o formato do olho',
  },
  {
    src: '/portfolio/antes-depois-03.jpg',
    alt: 'Close-up Volume Crystal — extensão de cílios dramática',
    label: 'Volume Crystal',
    sub: 'Resultado close-up',
  },
  {
    src: '/portfolio/antes-depois-04.jpg',
    alt: 'Volume Crystal antes e depois — close olho',
    label: 'Volume Crystal',
    sub: 'Definição e volume',
  },
  {
    src: '/portfolio/antes-depois-05.jpg',
    alt: 'Extensão Elegance antes e depois — Studio Crystal Lashes',
    label: 'Extensão Elegance',
    sub: 'Natural e sofisticado',
  },
  {
    src: '/portfolio/antes-depois-06.jpg',
    alt: 'Extensão de cílios antes e depois — resultado natural',
    label: 'Volume Crystal',
    sub: 'Resultado natural',
  },
  {
    src: '/portfolio/antes-depois-07.jpg',
    alt: 'Lash lifting antes e depois — Studio Crystal Lashes',
    label: 'Lash Lifting',
    sub: 'Cílios naturais realçados',
  },
  {
    src: '/portfolio/antes-depois-08.jpg',
    alt: 'Extensão de cílios Volume antes e depois',
    label: 'Volume Crystal',
    sub: 'Antes & depois',
  },
];
---

<Base
  title="Portfólio — Antes e Depois · Studio Crystal Lashes, Santo André"
  description="Veja as transformações realizadas pela Stefanie Moura no Studio Crystal Lashes. Extensão de cílios em Santo André, SP."
>

  <section class="page-hero section section--dark">
    <div class="container">
      <p class="eyebrow">Resultados reais</p>
      <h1 style="color: #fff;">Portfólio<br /><em>antes & depois</em></h1>
      <p style="color: rgba(255,255,255,0.6); margin-top: 16px; max-width: 480px; line-height: 1.7;">
        Cada resultado é único porque cada olho é único. Veja o que o Mapeamento Crystal entrega.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <div class="portfolio-grid">
        {photos.map((photo) => (
          <figure class="portfolio-item">
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
            />
            <figcaption class="portfolio-caption">
              <strong>{photo.label}</strong>
              <span>{photo.sub}</span>
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="instagram-cta text-center">
        <p class="text-muted">Veja mais resultados no Instagram</p>
        <a href="https://www.instagram.com/studiocrystallashes/" class="btn btn--primary" target="_blank" rel="noopener">
          @studiocrystallashes
        </a>
      </div>

    </div>
  </section>

  <section class="section section--dark">
    <div class="container text-center">
      <h2 style="color: #fff;">Quer ser a próxima<br /><em>transformação?</em></h2>
      <p style="color: rgba(255,255,255,0.6); margin: 16px 0 32px;">
        Agende sua avaliação e descubra qual técnica harmoniza melhor com o seu olhar.
      </p>
      <a href="https://wa.me/5511916637446?text=Ol%C3%A1%2C%20vi%20o%20portf%C3%B3lio%20e%20quero%20agendar!" class="btn btn--primary" target="_blank" rel="noopener">
        Agendar pelo WhatsApp
      </a>
    </div>
  </section>

</Base>

<style>
  .page-hero {
    padding: 100px 24px 60px;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    margin-bottom: 56px;
  }

  .portfolio-item {
    margin: 0;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #E2E8F0;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .portfolio-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(15, 40, 32, 0.12);
  }

  .portfolio-item img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .portfolio-caption {
    padding: 14px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #fff;
  }

  .portfolio-caption strong {
    font-size: 0.9rem;
    color: #0F2820;
  }

  .portfolio-caption span {
    font-size: 0.78rem;
    color: #94A3B8;
  }

  .instagram-cta {
    padding: 40px 0 0;
  }

  .instagram-cta p {
    margin-bottom: 16px;
  }
</style>
