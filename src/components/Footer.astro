<style>
  .footer {
    background: var(--footer-bg, #091a14);
    color: rgba(255,255,255,0.65);
    padding-top: 64px;
  }

  .footer__logo {
    font-family: var(--font-brand);
    font-size: 2rem;
    color: var(--calcita);
    text-decoration: none;
    line-height: 1;
    letter-spacing: 0.01em;
    display: inline-block;
    margin-bottom: 12px;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  @media (min-width: 640px) {
    .footer__inner { grid-template-columns: 2fr 1fr 1.5fr; gap: 48px; }
  }

  .footer__tagline {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .footer__socials {
    display: flex;
    gap: 16px;
    margin-top: 20px;
  }

  .footer__socials a {
    color: rgba(255,255,255,0.5);
    transition: color var(--transition-fast);
  }

  .footer__socials a:hover { color: var(--calcita); }
  .footer__socials a:nth-child(1):hover { color: #E4405F; }
  .footer__socials a:nth-child(2):hover { color: #fff; }
  .footer__socials a:nth-child(3):hover { color: #25D366; }

  .footer__links h4,
  .footer__contact h4 {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 16px;
  }

  .footer__links nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer__links nav a {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.65);
    transition: color var(--transition-fast);
  }

  .footer__links nav a:hover { color: #fff; }

  .footer__contact address {
    font-style: normal;
    font-size: 0.88rem;
    line-height: 1.8;
  }

  .footer__phone a {
    color: var(--calcita);
    font-weight: 500;
  }

  .footer__hours {
    margin-top: 12px;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    padding-top: 20px;
    padding-bottom: 20px;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
  }

  .footer__bottom a {
    color: var(--calcita);
    transition: color var(--transition-fast);
  }

  .footer__bottom a:hover { color: var(--white); }
</style>
