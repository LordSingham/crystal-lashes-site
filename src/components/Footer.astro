    <div class="footer__contact">
      <h4>Onde estamos</h4>
      <address>
        <p>Av. João Ramalho, 170, Sala 702</p>
        <p>Vila Assunção, Santo André, SP</p>
        <p>CEP 09030-320</p>
        <p class="footer__phone"><a href="https://wa.me/5511916637446">(11) 91663-7446</a></p>
