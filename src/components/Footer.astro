  <div class="footer__bottom container">
    <p>© {year} Studio Crystal Lashes · Vila Assunção, Santo André, SP</p>
    <p>Feito com carinho por <a href="https://sistemos.com.br" target="_blank" rel="noopener">Sistemos</a></p>
  </div>
