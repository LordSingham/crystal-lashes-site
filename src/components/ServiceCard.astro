---
interface Props {
  name: string;
  description: string;
  price: string;
  duration?: string;
  highlight?: boolean;
}

const { name, description, price, duration, highlight = false } = Astro.props;
const waText = encodeURIComponent(`Olá, gostaria de agendar ${name}!`);
---

<article class={`service-card ${highlight ? 'service-card--highlight' : ''}`}>
  {highlight && <span class="service-card__badge">✦ Exclusivo</span>}
  <div class="service-card__body">
    <h3 class="service-card__name">{name}</h3>
    <p class="service-card__desc">{description}</p>
    {duration && <p class="service-card__duration">{duration}</p>}
  </div>
  <div class="service-card__footer">
    <span class="service-card__price">{price}</span>
    <a
      href={`https://wa.me/5511916637446?text=${waText}`}
      class="btn btn--primary service-card__btn"
      target="_blank"
      rel="noopener"
      aria-label={`Agendar ${name}`}
    >
      Agendar
    </a>
  </div>
</article>

<style>
  .service-card {
    background: var(--white);
    border: var(--border-default);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    transition: box-shadow var(--transition), transform var(--transition);
    position: relative;
  }

  .service-card:hover {
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  .service-card--highlight {
    border-color: var(--calcita);
    box-shadow: 0 0 0 1px var(--calcita), var(--shadow-soft);
  }

  .service-card__badge {
    position: absolute;
    top: -1px;
    right: 24px;
    background: var(--calcita);
    color: var(--text-black);
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 0 0 var(--radius) var(--radius);
  }

  .service-card__name {
    font-size: 1.25rem;
    color: var(--teal-deep);
    margin-bottom: 8px;
  }

  .service-card__desc {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .service-card__duration {
    font-size: 0.75rem;
    color: var(--gray-400);
    margin-top: 10px;
    letter-spacing: 0.04em;
  }

  .service-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .service-card__price {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 400;
    font-style: italic;
    color: var(--teal-deep);
    font-variant-numeric: tabular-nums;
  }

  .service-card__btn {
    padding: 9px 18px;
    font-size: 0.72rem;
  }
</style>
