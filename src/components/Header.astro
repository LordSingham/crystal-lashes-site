---
const nav = [
  { label: 'Serviços', href: '/servicos' },
  { label: 'Resultados', href: '/resultados' },
  { label: 'Sobre', href: '/sobre' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contato', href: '/contato' },
];

const currentPath = Astro.url.pathname;
---

<header class="header" id="header">
  <div class="header__inner container">
    <a href="/" class="header__logo" aria-label="Studio Crystal Lashes — Página Inicial">
      Crystal Lashes
    </a>

    <nav class="header__nav" aria-label="Navegação principal">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class={`header__link ${currentPath.startsWith(href) ? 'header__link--active' : ''}`}
        >
          {label}
        </a>
      ))}
      <a
        href="https://wa.me/5511916637446?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20um%20hor%C3%A1rio!"
        class="btn btn--primary header__cta"
        target="_blank"
        rel="noopener"
      >
        Agendar
      </a>
    </nav>

    <div class="header__mobile-actions">
      <a
        href="https://wa.me/5511916637446?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20um%20hor%C3%A1rio!"
        class="header__wa-mobile"
        target="_blank"
        rel="noopener"
        aria-label="Agendar pelo WhatsApp"
      >
        Agendar
      </a>
      <button class="header__burger" id="burger" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobile-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .header::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: var(--scroll-pct, 0%);
    height: 2px;
    background: var(--calcita);
    transition: width 0.1s linear;
    pointer-events: none;
  }

  .header.scrolled {
    box-shadow: 0 4px 24px rgba(15,40,32,0.08);
    border-bottom-color: transparent;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .header__logo {
    font-family: var(--font-brand);
    font-size: 2.2rem;
    color: var(--teal-deep);
    text-decoration: none;
    line-height: 1;
    letter-spacing: 0.01em;
    transition: color var(--transition-fast);
  }

  .header__logo:hover {
    color: var(--calcita);
  }

  .header__nav {
    display: none;
    align-items: center;
    gap: 36px;
  }

  @media (min-width: 1024px) {
    .header__nav {
      display: flex;
    }
  }

  .header__link {
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: #555;
    transition: color var(--transition-fast);
    text-transform: uppercase;
  }

  .header__link:hover {
    color: var(--text-primary);
  }

  .header__link--active {
    color: var(--teal-deep);
    font-weight: 500;
  }

  .header__cta {
    padding: 10px 22px;
    font-size: 0.75rem;
  }

  /* Mobile actions */
  .header__mobile-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  @media (min-width: 1024px) {
    .header__mobile-actions {
      display: none;
    }
  }

  .header__wa-mobile {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--text-black);
    color: var(--white);
    padding: 9px 18px;
    border-radius: var(--radius-pill);
  }

  .header__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--teal-deep);
    transition: transform var(--transition-fast), opacity var(--transition-fast), background var(--transition-fast);
    transform-origin: center;
  }

  /* Mobile nav drawer */
  .header__nav--mobile {
    display: none;
    position: absolute;
    top: 72px;
    left: 0;
    right: 0;
    background: var(--white);
    flex-direction: column;
    align-items: flex-start;
    padding: 24px 20px;
    gap: 20px;
    border-bottom: 1px solid var(--line);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    z-index: 99;
  }

  .header__nav--mobile.open {
    display: flex;
  }

  .header__nav--mobile .header__link {
    font-size: 1rem;
  }
</style>

<nav class="header__nav--mobile" id="mobile-nav" aria-label="Navegação mobile" role="dialog" aria-modal="true" inert>
  {nav.map(({ label, href }) => (
    <a
      href={href}
      class={`header__link ${currentPath.startsWith(href) ? 'header__link--active' : ''}`}
    >
      {label}
    </a>
  ))}
</nav>

<script>
  const burger = document.getElementById('burger');
  const mobileNav = document.getElementById('mobile-nav');
  const header = document.getElementById('header');

  // Scroll effect + progress bar
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
    const pct = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
    document.documentElement.style.setProperty('--scroll-pct', `${Math.min(pct, 100)}%`);
  }, { passive: true });

  // Mobile nav toggle
  burger?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(isOpen));
    burger.setAttribute('aria-label', isOpen ? 'Fechar menu' : 'Abrir menu');
    if (isOpen) {
      mobileNav?.removeAttribute('inert');
    } else {
      mobileNav?.setAttribute('inert', '');
    }
  });

  document.addEventListener('click', (e) => {
    if (!burger?.contains(e.target as Node) && !mobileNav?.contains(e.target as Node)) {
      mobileNav?.classList.remove('open');
      mobileNav?.setAttribute('inert', '');
      burger?.setAttribute('aria-expanded', 'false');
      burger?.setAttribute('aria-label', 'Abrir menu');
    }
  });

  mobileNav?.querySelectorAll('.header__link').forEach((link) => {
    link.addEventListener('click', () => {
      mobileNav?.classList.remove('open');
      mobileNav?.setAttribute('inert', '');
      burger?.setAttribute('aria-expanded', 'false');
      burger?.setAttribute('aria-label', 'Abrir menu');
    });
  });
</script>
