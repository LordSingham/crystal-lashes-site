---
const nav = [
  { label: 'Sobre', href: '/sobre' },
  { label: 'Serviços', href: '/servicos' },
  { label: 'Portfólio', href: '/portfolio' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contato', href: '/contato' },
];

const currentPath = Astro.url.pathname;
---

<header class="header" id="header">
  <div class="header__inner container">
    <a href="/" class="header__logo" aria-label="Studio Crystal Lashes — Página Inicial">
      <img src="/logo.png" alt="Crystal Lashes — Extensão de Cílios Santo André" class="header__logo-img" />
    </a>

    <nav class="header__nav" aria-label="Navegação principal">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class={`header__link ${currentPath.startsWith(href) ? 'header__link--active' : ''}`}
        >
          {label}
        </a>
      ))}
      <a href="https://wa.me/5511916637446?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20um%20hor%C3%A1rio!" class="btn btn--primary header__cta" target="_blank" rel="noopener">
        Agendar
      </a>
    </nav>

    <button class="header__burger" id="burger" aria-label="Abrir menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #E2E8F0;
    transition: box-shadow 0.3s ease;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .header__logo {
    display: flex;
    align-items: center;
  }

  .header__logo-img {
    height: 44px;
    width: auto;
    display: block;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .header__link {
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #475569;
    transition: color 0.2s;
  }

  .header__link:hover {
    color: #0F2820;
  }

  .header__link--active {
    color: #006a60;
    border-bottom: 2px solid #5ECFBF;
    padding-bottom: 2px;
  }

  .header__cta {
    padding: 10px 20px;
    font-size: 0.8rem;
  }

  .header__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .header__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #0F2820;
    transition: all 0.25s;
    transform-origin: center;
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      background: #fff;
      flex-direction: column;
      align-items: flex-start;
      padding: 24px;
      gap: 20px;
      border-bottom: 1px solid #E2E8F0;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    .header__nav.open {
      display: flex;
    }

    .header__link {
      font-size: 1rem;
    }

    .header__burger {
      display: flex;
    }
  }
</style>

<script>
  const burger = document.getElementById('burger');
  const nav = document.querySelector('.header__nav');

  burger?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(isOpen));
  });
</script>
